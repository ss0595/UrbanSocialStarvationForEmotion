PORT=3000
JWT_SECRET=change-this-before-production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-before-production

# Choose one database path strategy.
# Local default:
SQLITE_DB_PATH=./database.sqlite

# Or set a persistent directory on hosts like Render / Railway:
# SQLITE_DB_DIR=/data
# RAILWAY_VOLUME_MOUNT_PATH=/data
# RENDER_DISK_PATH=/usr/src/app/data
